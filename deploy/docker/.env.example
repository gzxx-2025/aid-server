# ============================================================================
# AID Docker 部署配置（唯一配置真源）
#   首次部署必须先复制本模板：cp .env.example .env
#   之后所有配置调整都编辑 .env（本模板文件保持原样，升级时不会被覆盖）
# 密码/密钥类留空时部署脚本自动生成强随机值写回；
# 「生产调优」段默认值按 4核8G 服务器标定，按实际配置调节；
# 修改后执行 sudo bash aid.sh 菜单「重启服务」（或 docker compose up -d）生效。
# ============================================================================

# 统一数据根目录：程序产物(app/)、上传文件、日志、MySQL/Redis/RocketMQ 数据全部在此目录下，
# 备份或迁移整个目录即可。在线升级时升级器替换 app/ 下的产物文件。
DATA_ROOT=/data/aid

# 站点对外端口（Nginx）：HTTP_PORT=C端用户端，ADMIN_PORT=后台管理端
HTTP_PORT=80
ADMIN_PORT=8090

# ---------------- MySQL ----------------
# root 密码（留空=部署脚本自动生成强随机值）
MYSQL_ROOT_PASSWORD=
# 业务库名/账号（首次启动自动创建并导入 sql/ 目录脚本）
DB_NAME=aid
DB_USERNAME=aid
# 业务账号密码（留空=部署脚本自动生成强随机值）
DB_PASSWORD=
# 宿主机映射端口（仅绑定 127.0.0.1，供运维排查连接）
MYSQL_PORT=3306

# ---------------- Redis ----------------
# 默认使用内置 Redis 容器（COMPOSE_PROFILES 含 redis）；
# 使用外部 Redis：COMPOSE_PROFILES 去掉 redis，并把 REDIS_HOST/PORT 改为外部地址
REDIS_HOST=redis
REDIS_PORT=6379
# 留空表示无密码；生产建议设置强密码
REDIS_PASSWORD=

# ---------------- 后端 ----------------
# JWT 令牌密钥（留空=部署脚本自动生成强随机值；泄露等于全部账号失守）
TOKEN_SECRET=
# 后端在宿主机的映射端口（仅绑定 127.0.0.1，供运维排查）
BACKEND_PORT=8080

# ============================================================================
# 生产调优参数（可选，不设置则用默认值）
# ============================================================================

# 后端 JVM：8G 内存服务器建议 -Xms2g -Xmx4g；16G 建议 -Xms4g -Xmx8g
# 默认已带 G1GC 与 OOM 时自动转储堆快照到 logs 目录
#JAVA_OPTS=-Xms2g -Xmx4g -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/home/aid/logs

# MySQL InnoDB 缓冲池：建议物理内存的 40%~50%（8G 服务器 → 2G；16G → 6G）
#MYSQL_BUFFER_POOL=2G
# MySQL 最大连接数
#MYSQL_MAX_CONNECTIONS=500

# Redis 内存上限：超限后按 REDIS_MAXMEMORY_POLICY 处理
#REDIS_MAXMEMORY=1gb
# 淘汰策略：默认 noeviction（本系统 Redis 承载分布式锁，禁止静默淘汰；写满报错可见）
#REDIS_MAXMEMORY_POLICY=noeviction

# 用户端 Node 运行参数（如提高 SSR 内存上限）
#WEB_NODE_OPTIONS=--max-old-space-size=1024

# ---------------- 组件开关（COMPOSE_PROFILES 控制内置容器的启停） ----------------
# redis = 启动内置 Redis 容器；mq = 启动内置 RocketMQ 容器（NameServer+Broker）
# 组合示例：
#   COMPOSE_PROFILES=redis          内置 Redis，不用 MQ（默认，本地任务模式功能完整）
#   COMPOSE_PROFILES=redis,mq       内置 Redis + 内置 MQ（同时 ROCKETMQ_ENABLED=true）
#   COMPOSE_PROFILES=redis          内置 Redis + 外部 MQ（ROCKETMQ_ENABLED=true 并改 ROCKETMQ_NAMESERVER）
#   COMPOSE_PROFILES=               全外部 Redis/MQ（改 REDIS_HOST 与 ROCKETMQ_NAMESERVER）
COMPOSE_PROFILES=redis

# ---------------- RocketMQ（可选组件） ----------------
# 后端是否加载 MQ 能力：false=本地任务模式（默认，功能完整）
ROCKETMQ_ENABLED=false
# NameServer 地址：内置容器用默认值；外部 MQ 改为 IP:9876
ROCKETMQ_NAMESERVER=rocketmq-nameserver:9876
# NameServer JVM（很轻，默认 256m 足够）
#MQ_NAMESRV_JAVA_OPTS=-Xms256m -Xmx256m -Xmn128m
# Broker JVM：镜像默认 8G 大堆已被覆盖为 1G；消息量大时调到 -Xms2g -Xmx2g -Xmn1g 以上
#MQ_BROKER_JAVA_OPTS=-Xms2g -Xmx2g -Xmn1g
# 跨机使用本机 MQ：修改 rocketmq/broker.conf 的 brokerIP1 为本机IP，并为 broker 服务开放 10909/10911 端口
